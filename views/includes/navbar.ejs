<nav class="navbar navbar-expand-lg bg-body-tertiary sticky-top border-bottom">
  <div class="container-fluid">
    <a class="navbar-brand" href="/"><i class="fa-regular fa-compass"></i></a>
    <!-- LEFT OPTIONS (collapse) -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/listing">Explore</a>
      </div>
      </div>

      <form class="d-flex mx-auto col-lg-4 col-md-6 col-8 order-lg-0 order-1" role="search">
      <input class="form-control me-2 navsearch" type="search" placeholder="Search">

      <button class="btn sebtn d-flex align-items-center px-lg-4 px-2 py-2" type="submit">
      <i class="fa-solid fa-magnifying-glass me-1"></i>
     <span class="d-none d-lg-inline">Search</span>
      </button>
    </form>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

     
      <div class="navbar-nav ms-auto">
        
        <div class="form-check form-switch d-flex align-items-center me-3 tax-check">
            <label class="form-check-label me-1" for="switchCheckDefault">
              With Tax
              </label>
            <input class="form-check-input ms-1" type="checkbox" role="switch" id="switchCheckDefault">
          </div>

        <a class="nav-link" href="/listing/new">Wanderlust your home</a>
        

        <% if(currentUser){ %>
          <a class="nav-link">Welcome, <%= currentUser.username %></a>
          <a class="nav-link" href="/new/logout">Logout</a>
        <% } else { %>
          <a class="nav-link" href="/new/signup">Signin</a>
          <a class="nav-link" href="/new/login">Login</a>
        <% } %>
      </div>
    </div>

    

    <!-- HAMBURGER -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

  </div>
</nav>